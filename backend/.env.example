# Copy this file to .env and fill in the values
# Ask your teammate (Jainesh) for the real credentials

# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Snowflake (shared team DB — get from Jainesh) ────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=PROEDGE_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# ─── Google Gemini (get from Jainesh or create your own) ──
GEMINI_API_KEY=

# ─── Auth0 (not required in development) ─────────────────
AUTH0_DOMAIN=dev-mqukozzpm6v3pwff.us.auth0.com
AUTH0_AUDIENCE=https://proedge-api

# ─── Dev mode user ID (used when no Auth0 token present) ──
DEV_USER_ID=dev-user-001

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
