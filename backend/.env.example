# Copy this file to .env and fill in the values
# Ask your teammate (Jainesh) for the real credentials

# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Snowflake (shared team DB — get from Jainesh) ────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=PROEDGE_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# ─── Google Gemini (get from Jainesh or create your own) ──
GEMINI_API_KEY=

# ─── Email/password JWT (required in production — use a long random string) ──
JWT_SECRET=change-me-use-openssl-rand-hex-32-in-production
# Login/signup with “Remember me”: long session. Without: shorter session.
JWT_EXPIRES_IN_LONG=365d
JWT_EXPIRES_IN_SHORT=30d

# ─── Auth0 (optional — RS256 tokens still work if configured) ─────────────────
AUTH0_DOMAIN=dev-mqukozzpm6v3pwff.us.auth0.com
AUTH0_AUDIENCE=https://proedge-api

# ─── Dev mode user ID (when DEV_AUTH_BYPASS allows unauthenticated API calls) ──
DEV_USER_ID=dev-user-001

# Set false to require Authorization on every /api request in development
DEV_AUTH_BYPASS=true

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:5178","http://localhost:5179","http://localhost:3000"]
